# ─── Omgeving ─────────────────────────────────────────────────────────────────
ENVIRONMENT=production
API_BASE_URL=https://api.bewaardvoorjou.nl
APP_BASE_URL=https://bewaardvoorjou.nl
CORS_ORIGINS=https://bewaardvoorjou.nl,https://www.bewaardvoorjou.nl

# ─── Database (Neon.tech PostgreSQL) ─────────────────────────────────────────
DATABASE_URL=postgresql+psycopg://user:password@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require

# ─── Redis (Celery broker + result backend) ───────────────────────────────────
REDIS_URL=redis://default:password@redis-host:6379/0

# ─── Beveiliging — VERPLICHT IN PRODUCTIE ────────────────────────────────────
# Genereer met: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=

# ─── AI / OpenRouter ──────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-or-v1-...
OPENAI_API_BASE=https://openrouter.ai/api/v1
OPENAI_MODEL=anthropic/claude-sonnet-4-6

# ─── E-mail (Resend) ──────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=Bewaardvoorjou <noreply@bewaardvoorjou.nl>
RESEND_REPLY_TO_EMAIL=support@bewaardvoorjou.nl
RESEND_WEBHOOK_SIGNING_SECRET=whsec_...

# ─── Opslag (S3 / Tigris / Cloudflare R2) ────────────────────────────────────
S3_BUCKET=bewaardvoorjou-media
S3_REGION=eu-central-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Voor Cloudflare R2:
# S3_ENDPOINT_URL=https://<account>.r2.cloudflarestorage.com

# ─── Stripe Betalingen ────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Sentry (optioneel) ───────────────────────────────────────────────────────
SENTRY_DSN=https://...@sentry.io/...

# ─── SEO Indexering (optioneel) ───────────────────────────────────────────────
SITE_URL=https://bewaardvoorjou.nl
INDEXNOW_KEY=5ea345ef169f44a79679b5df61c1ea6b
GOOGLE_SERVICE_ACCOUNT_JSON=
