# Application Configuration
ENVIRONMENT=development
API_V1_PREFIX=/api/v1

# Database Configuration (Neon.tech PostgreSQL)
DATABASE_URL=postgresql+psycopg://user:password@host/database?sslmode=require

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# JWT Configuration - Generate with: openssl rand -hex 32
JWT_SECRET_KEY=your-secret-key-here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=1440

# AI Configuration (OpenRouter) - Get key from https://openrouter.ai/keys
OPENAI_API_KEY=sk-or-v1-your-key-here
OPENAI_API_BASE=https://openrouter.ai/api/v1
OPENAI_MODEL=anthropic/claude-sonnet-4-6

# Whisper Configuration
WHISPER_MODEL=openai/whisper-large-v3
WHISPER_BACKEND=openrouter

# S3 Configuration
S3_BUCKET=life-journey-media
S3_REGION=eu-central-1

# Telemetry
TELEMETRY_DISABLED=false

# Email Configuration (Resend — https://resend.com)
RESEND_API_KEY=re_your_key_here
RESEND_FROM_EMAIL=Bewaardvoorjou <noreply@bewaardvoorjou.nl>
RESEND_REPLY_TO_EMAIL=support@bewaardvoorjou.nl
# Webhook signing secret — get from Resend dashboard → Webhooks → Signing Secret
# Format: whsec_xxxxx
RESEND_WEBHOOK_SIGNING_SECRET=whsec_your_secret_here
APP_BASE_URL=https://bewaardvoorjou.nl

# Blog / SEO Indexing
SITE_URL=https://bewaardvoorjou.nl
INDEXNOW_KEY=
# Google Indexing API: plak hier de volledige JSON van je Service Account (op één regel)
GOOGLE_SERVICE_ACCOUNT_JSON=
